# Copy this to .env and fill in your values

# Camera identity (used as DynamoDB partition key and S3 folder name)
CAMERA_ID=cam-driveway

# Full RTSP URL of your IP camera
# Examples:
#   Reolink:   rtsp://admin:PASSWORD@192.168.1.50/h264Preview_01_main
#   Hikvision: rtsp://admin:PASSWORD@192.168.1.50:554/Streaming/Channels/101
#   Amcrest:   rtsp://admin:PASSWORD@192.168.1.50:554/cam/realmonitor?channel=1&subtype=0
#   Generic:   rtsp://192.168.1.50/stream
RTSP_URL=rtsp://admin:PASSWORD@192.168.1.50/stream1

# "entry", "exit", or "unknown"
EVENT_TYPE=unknown

# From your WatchTell deployment
MEDIA_BUCKET=watchtell-media-916918686359
QUEUE_URL=https://sqs.us-east-1.amazonaws.com/916918686359/watchtell-alpr-queue
AWS_REGION=us-east-1

# How many frames per second to evaluate for motion (1 is fine for plate capture)
CAPTURE_FPS=1

# Number of changed pixels required to trigger a keyframe upload.
# Lower = more sensitive. Set to 0 to capture every frame regardless of motion.
MOTION_THRESHOLD=2000

# Minimum seconds between uploads for this camera (prevents burst spam)
MIN_INTERVAL_SEC=3

# AWS credentials — leave blank if running with an IAM role (e.g. on EC2 or ECS)
# Otherwise set these to an IAM user with the relay policy attached.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
