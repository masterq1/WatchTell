{
  "expo": {
    "name": "WatchTell",
    "slug": "watchtell",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#12141a"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.watchtell.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to capture license plates for search.",
        "NSMicrophoneUsageDescription": "Required for video recording."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#12141a"
      },
      "package": "com.watchtell.app",
      "permissions": ["CAMERA", "RECORD_AUDIO"]
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#f59e0b",
          "sounds": []
        }
      ],
      ["expo-camera", { "cameraPermission": "Used to capture license plates." }]
    ],
    "scheme": "watchtell",
    "extra": {
      "eas": { "projectId": "your-eas-project-id" }
    }
  }
}
